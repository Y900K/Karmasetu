# Normalize line endings for text files across platforms
* text=auto
*.ts text
*.tsx text
*.js text
*.jsx text
*.mjs text
*.json text
*.css text
*.html text
*.md text
*.yaml text
*.yml text
*.txt text
*.svg text
*.xml text

# Binary files should not be normalized
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
